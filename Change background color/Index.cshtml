@model IEnumerable<ADODemo.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<h1>Products</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>ProdId</th>
            <th>ProdName</th>
            <th>ProdPrice</th>
            <th>ProdQty</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.ProdId</td>
            <td>@item.ProdName</td>
            <td>@item.ProdPrice</td>
            <td>@item.ProdQty</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ProdId">Edit</a> |
                <a asp-action="Delete" asp-route-id="@item.ProdId">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
