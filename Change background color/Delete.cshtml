@model ADODemo.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<h1>Delete Product</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <p><strong>ID:</strong> @Model.ProdId</p>
    <p><strong>Name:</strong> @Model.ProdName</p>
    <p><strong>Price:</strong> @Model.ProdPrice</p>
    <p><strong>Quantity:</strong> @Model.ProdQty</p>
</div>
<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.ProdId" />
    <button type="submit">Delete</button>
    <a asp-action="Index">Cancel</a>
</form>
